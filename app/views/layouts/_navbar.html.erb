<nav class="bg-white shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <div class="flex items-center">
        <%= link_to t('common.app_name'), root_path, class: "text-xl font-semibold text-gray-900" %>
      </div>
      
      <div class="flex items-center space-x-4">
        <%= link_to t("common.links.projects"), projects_path, class: "text-gray-600 hover:text-gray-900 px-3 py-2 rounded-md text-sm font-medium" %>

        <% if user_signed_in? %>
          <%= link_to current_user.name, edit_user_registration_path, class: "text-gray-600 hover:text-gray-900 px-3 py-2 rounded-md text-sm font-medium" %>
          <%= link_to t("common.links.sign_out"), destroy_user_session_path, data: { turbo_method: :delete, turbo_confirm: t(".confirmations.sign_out") }, class: "text-gray-600 hover:text-gray-900 px-3 py-2 rounded-md text-sm font-medium" %>
        <% else %>
          <%= link_to t("common.links.sign_in"), new_user_session_path, class: "text-gray-600 hover:text-gray-900 px-3 py-2 rounded-md text-sm font-medium" %>
        <% end %>
      </div>
    </div>
  </div>
</nav>

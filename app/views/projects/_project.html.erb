<div class="bg-white rounded-2xl shadow-2xl p-8 space-y-8">
  <!-- プロジェクトヘッダー -->
  <div class="border-b border-gray-200 pb-6">
    <div class="flex flex-wrap items-center gap-4 mb-4">
      <h1 class="text-4xl font-bold text-gray-900 mr-auto">
        <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
          <%= project.name %>
        </span>
      </h1>
      <div class="flex items-center space-x-3 ml-auto">
        <%= link_to edit_project_path(project), class: "inline-flex items-center py-2 px-4 border border-gray-300 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 focus:outline-none transition-all duration-200 shadow-md hover:shadow-lg" do %>
          <svg class="h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
          </svg>
          <%= t('.edit_this_project') %>
        <% end %>
       
        <%= link_to project_path(project), 
              data: { turbo_method: :delete, turbo_confirm: t(".confirm.are_you_sure") },
              class: "inline-flex items-center py-2 px-4 border border-red-300 text-sm font-medium rounded-lg text-red-700 bg-white hover:bg-red-50 focus:outline-none transition-all duration-200 shadow-md hover:shadow-lg" do %>
          <svg class="h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
          <%= t('.delete_this_project') %>
        <% end %>
        
        <div data-testid="project_complete">
          <% if project.completed? %>
            <span class="inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium bg-green-100 text-green-800">
              <svg class="h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <%= t('.status.completed') %>
            </span>
          <% else %>
            <%= button_to complete_project_path(project),
                  method: :patch,
                  class: "inline-flex items-center py-2 px-4 border border-transparent text-sm font-medium rounded-lg text-white bg-gradient-to-r from-green-600 to-green-700 hover:from-green-700 hover:to-green-800 focus:outline-none transition-all duration-200 shadow-lg hover:shadow-xl" do %>
              <svg class="h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <%= t('.status.complete') %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="mt-4 w-full w-4xl">
      <div class="bg-gray-50 rounded-lg p-2 border border-gray-200 h-64 overflow-y-auto">
        <div class="prose max-w-none text-gray-700">
          <%= simple_format project.description %>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4 mt-4">
      <div class="flex items-center text-sm text-gray-600">
        <svg class="h-5 w-5 mr-2 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
        </svg>
        <span class="font-medium"><%= Project.human_attribute_name(:owner) %>:</span>
        <span class="ml-2"><%= project.owner.name %></span>
      </div>
      <div class="flex items-center text-sm text-gray-600">
        <svg class="h-5 w-5 mr-2 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
        </svg>
        <span class="font-medium"><%= Project.human_attribute_name(:due_on) %>:</span>
        <span class="ml-2"><%= full_date(project.due_on) %></span>
      </div>
    </div>
  </div>

  <!-- タスクセクション -->
  <div>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-2xl font-bold text-gray-900">Tasks</h2>
      <%= link_to new_project_task_path(project), class: "inline-flex items-center py-2 px-4 border border-transparent text-sm font-medium rounded-lg text-white bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 focus:outline-none transition-all duration-200 shadow-lg hover:shadow-xl" do %>
        <svg class="h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
        </svg>
        Add Task
      <% end %>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Name
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
              Actions
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <%= render project.tasks %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ノートセクション -->
  <div>
    <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
      <h2 class="text-2xl font-bold text-gray-900">Notes</h2>
      <div class="flex items-center space-x-4">
        <%= form_with url: project_notes_path(project), method: :get, class: "flex items-center" do |f| %>
          <div class="relative">
            <%= f.search_field :term, 
                  placeholder: "Search notes",
                  class: "block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors duration-200" %>
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
              </svg>
            </div>
          </div>
        <% end %>
        <%= link_to new_project_note_path(project), class: "inline-flex items-center py-2 px-4 border border-transparent text-sm font-medium rounded-lg text-white bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 focus:outline-none transition-all duration-200 shadow-lg hover:shadow-xl" do %>
          <svg class="h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
          </svg>
          Add Note
        <% end %>
      </div>
    </div>

    <div class="space-y-4">
      <%= render project.notes %>
    </div>
  </div>
</div>
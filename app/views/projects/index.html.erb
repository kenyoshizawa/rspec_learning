<% provide(:title, t('.title')) %>

<div class="w-[900px] bg-gradient-to-br from-blue-50 to-indigo-100 min-h-screen p-4">
  <div class="max-w-4xl mx-auto">
    <div class="bg-white p-6 border-b-2 border-gray-200">
      <div class="flex justify-between items-center">
        <h1 class="text-4xl font-bold text-gray-900">
          <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
            <%= t('.heading') %>
          </span>
        </h1>
        <div data-testid="new_project">
          <%= link_to new_project_path, class: "flex items-center py-3 px-4 border border-transparent text-sm font-medium rounded-lg text-white bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 focus:outline-none transform transition-all duration-200 shadow-lg hover:shadow-xl" do %>
            <svg class="h-5 w-5 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
            </svg>
            <%= t('.new_project') %>
          <% end %>
        </div>
      </div>
    </div>

    <% if @projects.any? %>
      <div class="bg-white">
        <% @projects.each do |project| %>            
          <div class="p-6 border-b-2 border-gray-200 transition-colors duration-200 hover:bg-gray-100">
            <h2 class="text-2xl font-semibold text-gray-900 line-clamp-1">
              <%= link_to project.name, project, class: "text-blue-600 hover:text-blue-800 transition-colors duration-200" %>
            </h2>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white py-40 px-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <h3 class="mt-4 text-lg font-medium text-gray-900"><%= t('.no_projects') %></h3>
        <p class="mt-2 text-sm text-gray-500"><%= t('.no_projects_description') %></p>
      </div>
    <% end %>
  </div>
</div>

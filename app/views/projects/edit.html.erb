<% provide(:title, t('.title')) %>

<div class="min-w-[448px] bg-gradient-to-br from-blue-50 to-indigo-100 min-h-screen flex items-center justify-center p-4">
  <div class="max-w-md w-full space-y-8 bg-white rounded-2xl shadow-2xl p-8">
    <div class="text-center">
      <h1 class="text-4xl font-bold text-gray-900 mb-2">
        <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
          <%= t('.heading') %>
        </span>
      </h1>
      <p class="text-gray-600 text-lg">
        <%= t('.tagline') %>
      </p>
    </div>

    <%= render "form", project: @project %>

    <div class="pt-6 border-t border-gray-200">
      <div class="flex justify-center gap-4 text-sm">
        <%= link_to t('.show_this_project'), @project, class: "text-blue-600 hover:text-blue-800 font-medium transition-colors" %>
        <span class="text-gray-400">|</span>
        <%= link_to t('.back_to_projects'), projects_path, class: "text-blue-600 hover:text-blue-800 font-medium transition-colors" %>
      </div>
    </div>
  </div>
</div>
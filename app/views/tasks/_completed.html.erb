<%= turbo_frame_tag task do %>
  <%= form_with model: task, url: [:toggle, task.project, task], data: { controller: "task" } do |f| %>
    <label id="<%= dom_id(task) %>" class="flex items-center cursor-pointer group">
      <%= f.check_box :completed, 
            { data: { action: "change->task#submit" } },
            class: "h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:ring-offset-0 transition-colors duration-200 cursor-pointer" %>
      <span class="ml-3 text-sm font-medium text-gray-900 group-hover:text-blue-600 transition-colors duration-200 <%= task.completed? ? 'line-through text-gray-400' : '' %>">
        <%= task.name %>
      </span>
    </label>
  <% end %>
<% end %>